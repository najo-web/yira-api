generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client-sync"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_SYNC")
}

model YiraUtilisateur {
  id             String    @id @default(cuid())
  tenant_id      String    @default("CI") @db.VarChar(10)
  telephone      String?
  email          String?   @unique
  hashedPassword String?   @default("")
  nom            String?
  prenom         String?
  role           String    @default("BENEFICIAIRE")
  country_code   String    @default("CI")
  niveau_acces   String    @default("FREE")
  actif          Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  @@unique([telephone, country_code])
  @@map("yira_utilisateur")
}

model YiraOtpTemp {
  id           String   @id @default(cuid())
  tenant_id    String   @default("CI") @db.VarChar(10)
  telephone    String
  country_code String   @default("CI")
  code         String
  code_hash    String?
  expires_at   DateTime
  tentatives   Int      @default(0)
  created_at   DateTime @default(now())
  @@unique([telephone, country_code])
  @@map("yira_otp_temp")
}

model YiraSession {
  id          String    @id @default(uuid())
  tenant_id   String    @default("CI") @db.VarChar(10)
  user_id     String
  jwt_jti     String    @unique
  device_info Json?
  ip_address  String?   @db.VarChar(45)
  expires_at  DateTime
  revoked_at  DateTime?
  created_at  DateTime  @default(now())
  @@index([user_id])
  @@map("yira_session")
}

model YiraTransaction {
  id            String    @id @default(cuid())
  tenant_id     String    @default("CI") @db.VarChar(10)
  telephone     String
  country_code  String    @default("CI")
  montant       Int
  niveau_achete String
  operateur     String
  statut        String    @default("EN_ATTENTE")
  reference_ext String?
  created_at    DateTime  @default(now())
  confirmed_at  DateTime?
  @@index([telephone, country_code])
  @@map("yira_transaction")
}

model YiraConfigPays {
  id                String   @id @default(cuid())
  tenant_id         String   @default("CI") @db.VarChar(10)
  country_code      String   @unique
  nom               String
  code_ussd         String   @default("*7572#")
  langue_principale String   @default("fr")
  actif             Boolean  @default(true)
  freemium_actif    Boolean  @default(false)
  prix_basic        Int      @default(500)
  prix_premium      Int      @default(2000)
  @@map("yira_config_pays")
}

model YiraIAConfig {
  id               String  @id @default(cuid())
  module           String
  usage            String
  pays             String  @default("CI")
  modele_principal String  @default("gemini-2.5-flash")
  modele_fallback  String  @default("claude-haiku-4-5-20251001")
  prompt_template  String  @db.Text
  temperature      Float   @default(0.7)
  max_tokens       Int     @default(2000)
  actif            Boolean @default(true)
  @@unique([module, usage, pays])
  @@map("yira_ia_config")
}

model YiraIaLog {
  id           String   @id @default(cuid())
  module       String
  usage        String
  pays         String
  model_used   String
  was_fallback Boolean  @default(false)
  latency_ms   Int
  success      Boolean
  error        String?
  created_at   DateTime @default(now())
  @@map("yira_ia_log")
}

model YiraAuditLog {
  id          String   @id @default(cuid())
  action      String
  acteur_id   String?
  acteur_type String?
  ressource   String?
  details     Json?
  pays        String   @default("CI")
  created_at  DateTime @default(now())
  @@map("yira_audit_log")
}

model YiraSouscriptionVas {
  id           String    @id @default(uuid())
  tenant_id    String    @default("CI") @db.VarChar(10)
  user_id      String
  service_code String    @db.VarChar(50)
  statut       String    @default("ACTIF")
  opt_in_at    DateTime  @default(now())
  opt_out_at   DateTime?
  created_at   DateTime  @default(now())
  @@index([user_id, service_code])
  @@map("yira_souscription_vas")
}

model YiraNotification {
  id         String    @id @default(uuid())
  tenant_id  String    @default("CI") @db.VarChar(10)
  user_id    String
  canal      String    @default("SMS")
  contenu    String
  statut     String    @default("EN_ATTENTE")
  sent_at    DateTime?
  created_at DateTime  @default(now())
  @@index([user_id])
  @@map("yira_notification")
}

model YiraWebhookQueue {
  id           String    @id @default(uuid())
  tenant_id    String    @default("CI") @db.VarChar(10)
  source       String
  event_type   String
  payload      Json
  statut       String    @default("EN_ATTENTE")
  retry_count  Int       @default(0)
  processed_at DateTime?
  created_at   DateTime  @default(now())
  @@map("yira_webhook_queue")
}