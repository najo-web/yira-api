generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client-orientation"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_ORIENTATION_URL")
}

model YiraSession {
  id               String   @id @default(cuid())
  beneficiaire_id  String
  telephone        String
  country_code     String   @default("CI")
  canal            String   @default("APP")
  statut           String   @default("EN_COURS")
  created_at       DateTime @default(now())
  completed_at     DateTime?
  profil           YiraProfilRiasec?
  rapport          YiraRapportNie?

  @@index([telephone, country_code])
  @@map("yira_session")
}

model YiraProfilRiasec {
  id            String   @id @default(cuid())
  session_id    String   @unique
  telephone     String
  country_code  String   @default("CI")
  score_r       Int      @default(0)
  score_i       Int      @default(0)
  score_a       Int      @default(0)
  score_s       Int      @default(0)
  score_e       Int      @default(0)
  score_c       Int      @default(0)
  code_holland  String
  dominant      String
  bf_o          Int?
  bf_c          Int?
  bf_e          Int?
  bf_a          Int?
  bf_n          Int?
  v1_autonomie      Int?
  v2_impact         Int?
  v3_securite       Int?
  v4_excellence     Int?
  v5_lien_social    Int?
  v6_reconnaissance Int?
  apt_verbal    Int?
  apt_numerique Int?
  apt_logique   Int?
  apt_spatial   Int?
  apt_creativite Int?
  apt_global    Int?
  mo_calculee   Float?
  scg           Int      @default(0)
  trust_index   Int      @default(0)
  signal_conscience String @default("COHERENT")
  created_at    DateTime @default(now())
  session       YiraSession @relation(fields: [session_id], references: [id])

  @@index([telephone, country_code])
  @@map("yira_profil_riasec")
}

model YiraRapportNie {
  id                    String   @id @default(cuid())
  session_id            String   @unique
  telephone             String
  country_code          String   @default("CI")
  contenu               String   @db.Text
  filieres_recommandees String[]
  model_used            String
  latency_ms            Int
  restitution_faite     Boolean  @default(false)
  restitution_at        DateTime?
  created_at            DateTime @default(now())
  session               YiraSession @relation(fields: [session_id], references: [id])

  @@map("yira_rapport_nie")
}

model YiraTrustIndex {
  id               String   @id @default(cuid())
  telephone        String
  country_code     String   @default("CI")
  score_global     Int
  eligible_b2c     Boolean  @default(false)
  eligible_b2b     Boolean  @default(false)
  eligible_b2g     Boolean  @default(false)
  calcule_at       DateTime @default(now())

  @@index([telephone, country_code])
  @@map("yira_trust_index")
}

